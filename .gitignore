# ---------------------------------------------------------------------------
# Secrets & local configuration
# ---------------------------------------------------------------------------
# docker-compose.yml supplies sane defaults for every variable (${VAR:-default}),
# so `git clone` + `docker compose up --build` works WITHOUT this file. It holds
# per-developer overrides / credentials and must stay out of the public repo.
.env
.env.*
!.env.example

# ---------------------------------------------------------------------------
# Internal / non-public docs
# ---------------------------------------------------------------------------
requirements.docx

# Microsoft Office lock & temp files (e.g. ~$requirements.docx)
~$*
*.tmp

# ---------------------------------------------------------------------------
# Claude Code local settings
# ---------------------------------------------------------------------------
.claude/settings.local.json
.claude/*.local.json

# ---------------------------------------------------------------------------
# Java / Maven build output (rebuilt inside the Docker image)
# ---------------------------------------------------------------------------
target/
!**/src/main/**/target/
!**/src/test/**/target/
.mvn/wrapper/maven-wrapper.jar

# ---------------------------------------------------------------------------
# Node / frontend build output & dependencies (reinstalled at build time)
# ---------------------------------------------------------------------------
node_modules/
dist/
build/
.next/
.nuxt/
.cache/
.parcel-cache/
.vite/
coverage/
*.local

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------------------------------------------------------------------------
# IDE / editor metadata
# ---------------------------------------------------------------------------
.idea/
*.iml
*.iws
*.ipr
.vscode/
.settings/
.project
.classpath
.factorypath
.apt_generated
.springBeans
.sts4-cache/

# ---------------------------------------------------------------------------
# OS cruft
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
